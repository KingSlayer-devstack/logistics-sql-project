IF OBJECT_ID('Warehouse_stock', 'U') IS NOT NULL
    DROP TABLE Warehouse_stock;
GO

CREATE TABLE Warehouse_stock (
product_id INT PRIMARY KEY,
product_name VARCHAR(100),
category VARCHAR(50),
price DECIMAL(10, 2),
quantity INT,
shelf_location VARCHAR(10)
);

