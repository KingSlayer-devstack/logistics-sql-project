SELECT product_name, (price * quantity) AS total_stock_value
FROM Warehouse_stock;

SELECT product_name, price, shelf_location
FROM Warehouse_stock
WHERE shelf_location LIKE 'A%' AND price > 50;

SELECT product_name, quantity, shelf_location
FROM Warehouse_stock
WHERE quantity < (200 * 0.20);

SELECT SUM(quantity) AS total_items_in_warehouse
FROM Warehouse_stock;

SELECT AVG(price) AS average_product_price
FROM Warehouse_stock;

SELECT category, SUM(quantity) AS total_items, SUM(price * quantity) AS total_value
FROM Warehouse_stock
GROUP BY category;

SELECT product_name, category, shelf_location
FROM Warehouse_stock
WHERE quantity = 0;

SELECT product_name, quantity,
       CASE 
           WHEN quantity = 0 THEN 'OUT OF STOCK'
           WHEN quantity < 20 THEN 'CRITICAL'
           ELSE 'OK'
       END AS stock_status
FROM Warehouse_stock;

SELECT category, 
       SUM(quantity) AS total_items, 
       SUM(price * quantity) AS total_value
FROM Warehouse_stock
GROUP BY category
HAVING SUM(price * quantity) > 500;


