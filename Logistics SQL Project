GO

SELECT 
    T.transaction_id,
    P.product_name,
    P.category,
    T.movement_type,
    T.quantity_changed,
    T.transaction_date
FROM Warehouse_stock P
INNER JOIN Stock_Transactions T ON P.product_id = T.product_id
ORDER BY T.transaction_date DESC;

SELECT 
    P.product_name,
    SUM(T.quantity_changed) AS total_units_shipped
FROM Warehouse_stock P
INNER JOIN Stock_Transactions T ON P.product_id = T.product_id
WHERE T.movement_type = 'OUT'
GROUP BY P.product_name;
